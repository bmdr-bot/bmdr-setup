# Application
APP_NAME=bmdr-app
APP_ENV=dev
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=info

# Security
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*

# Database (optional — add if needed)
# DATABASE_URL=postgresql://user:pass@db:5432/dbname

# Redis (optional — add if needed)
# REDIS_URL=redis://redis:6379/0

# Cloudflare Tunnel (required for production)
CF_TUNNEL_TOKEN=

# Monitoring (optional)
# SENTRY_DSN=
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
